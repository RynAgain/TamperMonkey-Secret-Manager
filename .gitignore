# ============================================================
# TamperMonkey Secret Manager -- .gitignore
# ============================================================

# ----------------------------------------------------------
# Dependencies
# ----------------------------------------------------------
node_modules/

# ----------------------------------------------------------
# Build output
# ----------------------------------------------------------
dist/
target/
src-tauri/target/

# ----------------------------------------------------------
# Secrets, keys, and tokens -- CRITICAL
# Never commit any credential material regardless of path.
# ----------------------------------------------------------
*.tmvault
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.token
*.secret
api.port
api.token

# ----------------------------------------------------------
# Application data / databases
# SQLite databases may contain encrypted secrets or audit
# logs and must never be committed.
# ----------------------------------------------------------
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
*.sqlite-journal

# ----------------------------------------------------------
# Tauri build artifacts
# ----------------------------------------------------------
src-tauri/WixTools/
src-tauri/gen/

# ----------------------------------------------------------
# IDE and editor configuration
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------
# OS-generated files
# ----------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----------------------------------------------------------
# Test artifacts
# ----------------------------------------------------------
*.test.vault
*.test.db
coverage/

# ----------------------------------------------------------
# Logs and diagnostics
# ----------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------
# Environment files
# ----------------------------------------------------------
.env
.env.*
!.env.example

# ----------------------------------------------------------
# Miscellaneous
# ----------------------------------------------------------
*.tsbuildinfo
